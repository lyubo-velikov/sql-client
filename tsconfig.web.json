{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "outDir": "./out",
    "declaration": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/renderer/src/**/*"]
}
